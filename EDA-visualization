      "source": [
        "volatility = returns.std()\n",
        "\n",
        "volatility.plot(kind=\"bar\")\n",
        "\n",
        "plt.title(\"Volatility Comparison\")\n",
        "plt.ylabel(\"Std Dev\")\n",
        "plt.show()\n",
        "rolling_mean = data[\"THYAO.IS\"].rolling(20).mean()\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "data[\"THYAO.IS\"].plot(label=\"Price\")\n",
        "rolling_mean.plot(label=\"20-day MA\")\n",
        "\n",
        "plt.legend()\n",
        "plt.title(\"Price vs Moving Average\")\n",
        "plt.show()\n",
        "\n",
        "# Fix: Define market_return as the mean of all stock returns\n",
        "market_return = returns.mean(axis=1)\n",
        "\n",
        "aligned_market = market_return.loc[returns.index]\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "plt.scatter(aligned_market, returns[\"THYAO.IS\"], alpha=0.5)\n",
        "\n",
        "plt.xlabel(\"BIST100 Return\")\n",
        "plt.ylabel(\"THYAO Return\")\n",
        "plt.title(\"Market vs Stock Relationship\")\n",
        "\n",
        "plt.show()\n",
        "cum_returns = (1 + returns).cumprod()\n",
        "\n",
        "plt.figure(figsize=(12,6))\n",
        "for col in cum_returns.columns:\n",
        "    cum_returns[col].plot(label=col)\n",
        "\n",
        "plt.title(\"Cumulative Returns Comparison\")\n",
        "plt.legend()\n",
        "plt.show()"
